# ─── Medicire Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored. NEVER commit real credentials.

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Backend API ─────────────────────────────────────────────────────────────
API_BASE_URL=https://api.medicire.app/v1
SOCKET_URL=https://api.medicire.app

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── Mappls (MapMyIndia) Maps ─────────────────────────────────────────────────
# Obtain from https://auth.mappls.com/console → REST/Map SDK Key + KeyPair
MAPPLS_MAP_SDK_KEY=your_map_sdk_key
MAPPLS_CLIENT_ID=your_atlas_client_id
MAPPLS_CLIENT_SECRET=your_atlas_client_secret

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to 'true' only in development. Must be 'false' (or absent) in production.
USE_MOCK=true

